{
  "name": "clipboard-tool",
  "version": "0.1.0",
  "description": "A local Windows clipboard history manager.",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "smoke": "powershell -ExecutionPolicy Bypass -File scripts/smoke-test.ps1",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Jackson",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jackson.clipboardtool",
    "productName": "沾沾",
    "asarUnpack": [
      "src/double-tab-listener.ps1"
    ],
    "directories": {
      "output": "dist-zhan"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
